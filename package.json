{
  "name": "screenshotter-workspace",
  "version": "0.1.13",
  "private": true,
  "description": "Workspace for the @zohaibarsalan/screenshotter React capture package.",
  "scripts": {
    "build": "pnpm --filter @zohaibarsalan/screenshotter run build",
    "test": "pnpm --filter @zohaibarsalan/screenshotter run test",
    "release:check": "pnpm run build && pnpm run test && pnpm --filter @zohaibarsalan/screenshotter pack --pack-destination /tmp",
    "release:publish": "npm publish ./packages/widget --access public"
  },
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "screenshot",
    "react",
    "capture",
    "ui"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.14.0",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "jsdom": "^27.0.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
